
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Box Shadow | Developer OS</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../style.css">
  <style>
    .preview-area { display:flex; justify-content:center; align-items:center; background:var(--surface); border:1px solid var(--border); border-radius:14px; height:200px; margin-bottom:24px; }
    .preview-box { width:120px; height:80px; background:#6c63ff; border-radius:10px; transition:box-shadow 0.2s; }
    .slider-row { display:flex; align-items:center; gap:14px; margin-bottom:14px; }
    .slider-label { width:110px; font-size:0.8rem; color:var(--muted); }
    .slider-val { width:50px; font-family:'JetBrains Mono',monospace; font-size:0.8rem; text-align:right; }
    .slider-row input[type=range] { flex:1; accent-color:var(--accent); }
    .css-out { font-family:'JetBrains Mono',monospace; font-size:0.82rem; background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:14px; margin-top:16px; word-break:break-all; }
  </style>
</head>
<body>
<div class="page-header">
  <a href="../index.html" class="back-btn">← Back</a>
  <span class="page-title">📦 Box Shadow Generator</span>
</div>
<div class="container">
  <div class="preview-area"><div class="preview-box" id="box"></div></div>
  <div id="sliders">
    <div class="slider-row"><span class="slider-label">Horizontal</span><input type="range" id="x" min="-50" max="50" value="5" oninput="update()"><span class="slider-val" id="xv">5px</span></div>
    <div class="slider-row"><span class="slider-label">Vertical</span><input type="range" id="y" min="-50" max="50" value="5" oninput="update()"><span class="slider-val" id="yv">5px</span></div>
    <div class="slider-row"><span class="slider-label">Blur</span><input type="range" id="blur" min="0" max="100" value="20" oninput="update()"><span class="slider-val" id="blurv">20px</span></div>
    <div class="slider-row"><span class="slider-label">Spread</span><input type="range" id="spread" min="-30" max="50" value="0" oninput="update()"><span class="slider-val" id="spreadv">0px</span></div>
    <div class="slider-row"><span class="slider-label">Opacity</span><input type="range" id="alpha" min="0" max="100" value="40" oninput="update()"><span class="slider-val" id="alphav">40%</span></div>
    <div class="slider-row">
      <span class="slider-label">Color</span>
      <input type="color" id="color" value="#000000" oninput="update()" style="height:36px;border-radius:6px;border:1px solid var(--border);padding:2px;cursor:pointer;background:none">
      <label style="margin-left:10px;display:flex;gap:6px;align-items:center;font-size:0.8rem;color:var(--muted)"><input type="checkbox" id="inset" onchange="update()"> Inset</label>
    </div>
  </div>
  <div class="flex mt">
    <button class="btn btn-secondary" onclick="copy()">📋 Copy CSS</button>
  </div>
  <div class="css-out" id="css-out"></div>
</div>
<div class="toast" id="toast">Copied!</div>
<script>
  function hexToRgba(hex,a){const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);return `rgba(${r},${g},${b},${a})`;}
  function update(){
    const x=document.getElementById('x').value;
    const y=document.getElementById('y').value;
    const blur=document.getElementById('blur').value;
    const spread=document.getElementById('spread').value;
    const alpha=document.getElementById('alpha').value/100;
    const color=document.getElementById('color').value;
    const inset=document.getElementById('inset').checked?'inset ':'';
    document.getElementById('xv').textContent=x+'px';
    document.getElementById('yv').textContent=y+'px';
    document.getElementById('blurv').textContent=blur+'px';
    document.getElementById('spreadv').textContent=spread+'px';
    document.getElementById('alphav').textContent=Math.round(alpha*100)+'%';
    const shadow=`${inset}${x}px ${y}px ${blur}px ${spread}px ${hexToRgba(color,alpha.toFixed(2))}`;
    document.getElementById('box').style.boxShadow=shadow;
    document.getElementById('css-out').textContent=`box-shadow: ${shadow};`;
  }
  function copy(){navigator.clipboard.writeText(document.getElementById('css-out').textContent).then(()=>{const t=document.getElementById('toast');t.classList.add('show');setTimeout(()=>t.classList.remove('show'),1800);});}
  update();
</script>
</body></html>
