
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>PX ↔ REM | Developer OS</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../style.css">
  <style>
    .big-input { font-size:2rem !important; font-weight:700; text-align:center; padding:20px !important; }
    .arrow { text-align:center; font-size:1.5rem; color:var(--muted); margin:10px 0; }
    .base-row { display:flex; align-items:center; gap:10px; margin-top:20px; font-size:0.85rem; color:var(--muted); }
    .base-row input { width:80px; }
    .table-wrap { margin-top:24px; overflow-x:auto; }
    table { width:100%; border-collapse:collapse; font-size:0.82rem; }
    th { text-align:left; color:var(--muted); font-weight:600; padding:8px 12px; border-bottom:1px solid var(--border); }
    td { padding:8px 12px; border-bottom:1px solid var(--border); font-family:'JetBrains Mono',monospace; }
    tr:hover td { background:var(--surface); }
  </style>
</head>
<body>
<div class="page-header">
  <a href="../index.html" class="back-btn">← Back</a>
  <span class="page-title">📐 PX ↔ REM Converter</span>
</div>
<div class="container">
  <div class="row">
    <div class="col">
      <label style="text-align:center;display:block">PX</label>
      <input type="number" id="px" class="big-input" value="16" oninput="fromPx()">
    </div>
    <div style="align-self:center;font-size:1.5rem;color:var(--muted);padding-top:20px">↔</div>
    <div class="col">
      <label style="text-align:center;display:block">REM</label>
      <input type="number" id="rem" class="big-input" value="1" step="0.001" oninput="fromRem()">
    </div>
  </div>
  <div class="base-row">
    <span>Base font size:</span>
    <input type="number" id="base" value="16" min="1" oninput="fromPx()">
    <span>px</span>
  </div>
  <div class="table-wrap">
    <table>
      <thead><tr><th>PX</th><th>REM</th><th>EM (same base)</th></tr></thead>
      <tbody id="tbl"></tbody>
    </table>
  </div>
</div>
<script>
  function base(){return +document.getElementById('base').value||16;}
  function fromPx(){const px=+document.getElementById('px').value;document.getElementById('rem').value=(px/base()).toFixed(4);buildTable();}
  function fromRem(){const rem=+document.getElementById('rem').value;document.getElementById('px').value=(rem*base()).toFixed(2);buildTable();}
  function buildTable(){
    const b=base();
    const sizes=[8,10,12,14,16,18,20,24,28,32,36,40,48,56,64,72,96];
    document.getElementById('tbl').innerHTML=sizes.map(px=>`<tr><td>${px}px</td><td>${(px/b).toFixed(4)}rem</td><td>${(px/b).toFixed(4)}em</td></tr>`).join('');
  }
  buildTable();
</script>
</body></html>
