<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>JSON Minifier – Developer OS</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  body{font-family:'Poppins',sans-serif;background:#0d0d1a;color:#e2e8f0;min-height:100vh}
  a.back{display:inline-flex;align-items:center;gap:8px;color:#a5b4fc;text-decoration:none;font-size:.85rem;font-weight:500;margin-bottom:28px;transition:color .2s}
  a.back:hover{color:#fff}
  header{background:linear-gradient(160deg,#111128 0%,#1a1a3e 100%);text-align:center;padding:40px 20px 32px;border-bottom:1px solid rgba(99,102,241,.25)}
  header h1{font-size:2rem;font-weight:700;color:#fff}
  header p{font-size:.95rem;color:#94a3b8;margin-top:6px}
  .container{max-width:800px;margin:0 auto;padding:36px 24px}
  label{display:block;font-size:.82rem;font-weight:600;color:#94a3b8;margin-bottom:8px;text-transform:uppercase;letter-spacing:1px}
  textarea{width:100%;background:#111128;border:1px solid rgba(99,102,241,.3);color:#e2e8f0;font-family:'Courier New',monospace;font-size:.88rem;border-radius:10px;padding:12px 16px;outline:none;transition:border-color .2s;resize:vertical;min-height:180px}
  textarea:focus{border-color:#6366f1}
  .btn-row{display:flex;flex-wrap:wrap;gap:10px;margin-top:16px}
  .btn{display:inline-flex;align-items:center;gap:8px;background:#6366f1;color:#fff;border:none;padding:11px 24px;border-radius:10px;font-family:'Poppins',sans-serif;font-size:.9rem;font-weight:600;cursor:pointer;transition:background .2s,transform .15s}
  .btn:hover{background:#4f46e5;transform:translateY(-1px)}
  .btn-ghost{background:transparent;border:1px solid rgba(99,102,241,.4);color:#a5b4fc}
  .btn-ghost:hover{background:rgba(99,102,241,.1)}
  .stats{display:flex;gap:20px;margin-top:16px;flex-wrap:wrap}
  .stat{background:#111128;border:1px solid rgba(99,102,241,.2);border-radius:10px;padding:12px 18px;font-size:.82rem;color:#94a3b8}
  .stat strong{display:block;font-size:1.1rem;color:#a5b4fc;font-weight:700}
  .error{color:#f87171;font-size:.85rem;margin-top:10px}
  .toast{position:fixed;bottom:24px;right:24px;background:#6366f1;color:#fff;padding:12px 20px;border-radius:10px;font-size:.85rem;font-weight:600;opacity:0;pointer-events:none;transition:opacity .3s;z-index:999}
  .toast.show{opacity:1}
</style>
</head>
<body>
<header><h1>📦 JSON Minifier</h1><p>Compress and minify JSON to save space</p></header>
<div class="container">
  <a class="back" href="../index.html">← Back to Developer OS</a>
  <div class="section" style="margin-bottom:20px">
    <label>Input JSON</label>
    <textarea id="input" placeholder='Paste your JSON here...\n{\n  "name": "Developer OS",\n  "version": "1.0"\n}'></textarea>
  </div>
  <div class="btn-row">
    <button class="btn" onclick="minify()">📦 Minify</button>
    <button class="btn btn-ghost" onclick="copy()">📋 Copy</button>
    <button class="btn btn-ghost" onclick="clearAll()">🗑 Clear</button>
  </div>
  <div class="error" id="error"></div>
  <div class="stats" id="stats" style="display:none">
    <div class="stat"><strong id="origSize">-</strong>Original Size</div>
    <div class="stat"><strong id="minSize">-</strong>Minified Size</div>
    <div class="stat"><strong id="saved">-</strong>Saved</div>
  </div>
  <label style="margin-top:24px">Minified Output</label>
  <textarea id="output" readonly placeholder="Minified JSON will appear here..."></textarea>
</div>
<div class="toast" id="toast">Copied!</div>
<script>
  function minify() {
    const input = document.getElementById('input').value.trim();
    document.getElementById('error').textContent = '';
    document.getElementById('stats').style.display = 'none';
    try {
      const parsed = JSON.parse(input);
      const minified = JSON.stringify(parsed);
      document.getElementById('output').value = minified;
      const orig = new Blob([input]).size;
      const min = new Blob([minified]).size;
      const pct = ((orig-min)/orig*100).toFixed(1);
      document.getElementById('origSize').textContent = orig + ' B';
      document.getElementById('minSize').textContent = min + ' B';
      document.getElementById('saved').textContent = pct + '%';
      document.getElementById('stats').style.display = 'flex';
    } catch(e) { document.getElementById('error').textContent = '❌ Invalid JSON: ' + e.message; }
  }
  function copy() {
    navigator.clipboard.writeText(document.getElementById('output').value);
    const t=document.getElementById('toast');t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000);
  }
  function clearAll() { document.getElementById('input').value=''; document.getElementById('output').value=''; document.getElementById('stats').style.display='none'; document.getElementById('error').textContent=''; }
</script>
</body></html>
