<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>API Tester – Developer OS</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  body{font-family:'Poppins',sans-serif;background:#0d0d1a;color:#e2e8f0;min-height:100vh}
  a.back{display:inline-flex;align-items:center;gap:8px;color:#a5b4fc;text-decoration:none;font-size:.85rem;font-weight:500;margin-bottom:28px;transition:color .2s}
  a.back:hover{color:#fff}
  header{background:linear-gradient(160deg,#111128 0%,#1a1a3e 100%);text-align:center;padding:40px 20px 32px;border-bottom:1px solid rgba(99,102,241,.25)}
  header h1{font-size:2rem;font-weight:700;color:#fff}
  header p{font-size:.95rem;color:#94a3b8;margin-top:6px}
  .container{max-width:900px;margin:0 auto;padding:36px 24px}
  label{display:block;font-size:.82rem;font-weight:600;color:#94a3b8;margin-bottom:8px;text-transform:uppercase;letter-spacing:1px}
  input[type=text],select,textarea{width:100%;background:#111128;border:1px solid rgba(99,102,241,.3);color:#e2e8f0;font-family:'Poppins',sans-serif;font-size:.9rem;border-radius:10px;padding:12px 16px;outline:none;transition:border-color .2s}
  textarea{font-family:'Courier New',monospace;font-size:.85rem;resize:vertical;min-height:120px}
  input:focus,select:focus,textarea:focus{border-color:#6366f1}
  .url-row{display:grid;grid-template-columns:120px 1fr auto;gap:10px;align-items:end;margin-bottom:20px}
  select{padding:12px 10px}
  .btn{display:inline-flex;align-items:center;gap:8px;background:#6366f1;color:#fff;border:none;padding:12px 24px;border-radius:10px;font-family:'Poppins',sans-serif;font-size:.9rem;font-weight:600;cursor:pointer;transition:background .2s,transform .15s;white-space:nowrap}
  .btn:hover{background:#4f46e5;transform:translateY(-1px)}
  .btn:disabled{background:#374151;cursor:not-allowed;transform:none}
  .tabs{display:flex;gap:4px;margin-bottom:16px;border-bottom:1px solid rgba(99,102,241,.15);padding-bottom:0}
  .tab{padding:9px 18px;font-size:.85rem;font-weight:600;color:#64748b;cursor:pointer;border-radius:8px 8px 0 0;transition:all .2s;border:none;background:transparent}
  .tab.active{color:#a5b4fc;background:rgba(99,102,241,.1);border:1px solid rgba(99,102,241,.2);border-bottom:none}
  .tab-content{display:none}.tab-content.active{display:block}
  .response-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px}
  .badge{display:inline-block;padding:4px 12px;border-radius:999px;font-size:.78rem;font-weight:700}
  .badge-green{background:rgba(16,185,129,.15);color:#34d399;border:1px solid rgba(16,185,129,.3)}
  .badge-red{background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.3)}
  .badge-yellow{background:rgba(245,158,11,.15);color:#fbbf24;border:1px solid rgba(245,158,11,.3)}
  .response-box{background:#0a0a14;border:1px solid rgba(99,102,241,.2);border-radius:12px;padding:18px;font-family:'Courier New',monospace;font-size:.82rem;color:#cbd5e1;white-space:pre-wrap;word-break:break-all;min-height:120px;max-height:400px;overflow-y:auto}
  .headers-list{background:#111128;border:1px solid rgba(99,102,241,.15);border-radius:10px;padding:16px;margin-bottom:12px}
  .header-row{display:grid;grid-template-columns:1fr 1fr auto;gap:8px;margin-bottom:8px;align-items:center}
  .header-row input{margin:0}
  .remove-btn{background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);color:#f87171;border-radius:6px;padding:8px 10px;cursor:pointer;font-size:.8rem}
  .remove-btn:hover{background:rgba(239,68,68,.25)}
  .add-btn{background:transparent;border:1px solid rgba(99,102,241,.3);color:#a5b4fc;border-radius:6px;padding:6px 14px;font-size:.82rem;cursor:pointer;margin-top:4px}
  .add-btn:hover{background:rgba(99,102,241,.1)}
  .section{margin-bottom:24px}
  @media(max-width:600px){.url-row{grid-template-columns:1fr;grid-template-rows:auto auto auto}}
</style>
</head>
<body>
<header><h1>📡 API Tester</h1><p>Test HTTP requests — GET, POST, PUT, DELETE</p></header>
<div class="container">
  <a class="back" href="../index.html">← Back to Developer OS</a>
  <div class="url-row">
    <div><label>Method</label>
      <select id="method">
        <option>GET</option><option>POST</option><option>PUT</option><option>PATCH</option><option>DELETE</option>
      </select>
    </div>
    <div><label>URL</label><input type="text" id="url" placeholder="https://jsonplaceholder.typicode.com/posts/1"></div>
    <div style="padding-top:26px"><button class="btn" id="sendBtn" onclick="sendRequest()">▶ Send</button></div>
  </div>
  <div class="tabs">
    <button class="tab active" onclick="switchTab('headers',this)">Headers</button>
    <button class="tab" onclick="switchTab('body',this)">Body</button>
  </div>
  <div class="tab-content active" id="tab-headers">
    <div class="headers-list" id="headersList">
      <div class="header-row"><input type="text" placeholder="Key" value="Content-Type"><input type="text" placeholder="Value" value="application/json"><button class="remove-btn" onclick="this.parentElement.remove()">✕</button></div>
    </div>
    <button class="add-btn" onclick="addHeader()">+ Add Header</button>
  </div>
  <div class="tab-content" id="tab-body">
    <label>Request Body (JSON)</label>
    <textarea id="reqBody" placeholder='{\n  "title": "Test",\n  "body": "Hello world",\n  "userId": 1\n}'></textarea>
  </div>
  <div class="section" style="margin-top:24px">
    <div class="response-header">
      <label style="margin:0">Response</label>
      <div id="statusBadge"></div>
    </div>
    <div class="response-box" id="responseBox">Response will appear here after sending a request...</div>
  </div>
</div>
<script>
  function switchTab(name,btn){
    document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-'+name).classList.add('active');
  }
  function addHeader(){
    const list=document.getElementById('headersList');
    const row=document.createElement('div');row.className='header-row';
    row.innerHTML='<input type="text" placeholder="Key"><input type="text" placeholder="Value"><button class="remove-btn" onclick="this.parentElement.remove()">✕</button>';
    list.appendChild(row);
  }
  async function sendRequest(){
    const method=document.getElementById('method').value;
    const url=document.getElementById('url').value.trim();
    const resBox=document.getElementById('responseBox');
    const statusBadge=document.getElementById('statusBadge');
    if(!url){resBox.textContent='Please enter a URL.';return;}
    const btn=document.getElementById('sendBtn');btn.disabled=true;btn.textContent='⏳ Sending...';
    const headers={};
    document.querySelectorAll('#headersList .header-row').forEach(row=>{
      const inputs=row.querySelectorAll('input');
      if(inputs[0].value&&inputs[1].value) headers[inputs[0].value]=inputs[1].value;
    });
    const opts={method,headers};
    if(['POST','PUT','PATCH'].includes(method)){opts.body=document.getElementById('reqBody').value;}
    try{
      const start=Date.now();
      const res=await fetch(url,opts);
      const time=Date.now()-start;
      const text=await res.text();
      let display=text;
      try{display=JSON.stringify(JSON.parse(text),null,2);}catch(e){}
      resBox.textContent=display;
      const cls=res.ok?'badge-green':res.status<500?'badge-yellow':'badge-red';
      statusBadge.innerHTML=`<span class="badge ${cls}">${res.status} ${res.statusText}</span> <span style="font-size:.78rem;color:#64748b">${time}ms</span>`;
    }catch(e){
      resBox.textContent='❌ Error: '+e.message+'\n\nThis may be due to CORS restrictions. Try a public API.';
      statusBadge.innerHTML='<span class="badge badge-red">Error</span>';
    }
    btn.disabled=false;btn.textContent='▶ Send';
  }
</script>
</body></html>
