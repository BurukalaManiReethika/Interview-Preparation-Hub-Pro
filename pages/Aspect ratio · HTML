
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Aspect Ratio | Developer OS</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../style.css">
  <style>
    .preview-rect { margin:20px auto; background:var(--accent); border-radius:8px; opacity:0.7; transition:all 0.2s; max-width:100%; }
    .ratio-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(130px,1fr)); gap:10px; margin-top:20px; }
    .ratio-chip { background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:12px; text-align:center; cursor:pointer; transition:border-color .15s; }
    .ratio-chip:hover { border-color:var(--accent); }
    .ratio-chip .r { font-family:'JetBrains Mono',monospace; font-weight:700; font-size:0.95rem; color:var(--accent); }
    .ratio-chip .n { font-size:0.72rem; color:var(--muted); margin-top:3px; }
  </style>
</head>
<body>
<div class="page-header">
  <a href="../index.html" class="back-btn">← Back</a>
  <span class="page-title">🖼️ Aspect Ratio Calculator</span>
</div>
<div class="container">
  <div class="row mb">
    <div class="col"><label>Width (px)</label><input type="number" id="w" value="1920" oninput="fromW()"></div>
    <div class="col"><label>Height (px)</label><input type="number" id="h" value="1080" oninput="fromH()"></div>
  </div>
  <div class="output-box" id="ratio-out" style="margin-bottom:16px"></div>
  <div id="preview-wrap" style="text-align:center">
    <div class="preview-rect" id="rect" style="width:320px;height:180px"></div>
  </div>
  <div class="divider"></div>
  <label>Common Ratios</label>
  <div class="ratio-grid">
    <div class="ratio-chip" onclick="setRatio(16,9)"><div class="r">16:9</div><div class="n">Widescreen HD</div></div>
    <div class="ratio-chip" onclick="setRatio(4,3)"><div class="r">4:3</div><div class="n">Standard SD</div></div>
    <div class="ratio-chip" onclick="setRatio(1,1)"><div class="r">1:1</div><div class="n">Square</div></div>
    <div class="ratio-chip" onclick="setRatio(21,9)"><div class="r">21:9</div><div class="n">Ultrawide</div></div>
    <div class="ratio-chip" onclick="setRatio(3,2)"><div class="r">3:2</div><div class="n">Camera / 35mm</div></div>
    <div class="ratio-chip" onclick="setRatio(9,16)"><div class="r">9:16</div><div class="n">Portrait / Mobile</div></div>
    <div class="ratio-chip" onclick="setRatio(2,3)"><div class="r">2:3</div><div class="n">Portrait photo</div></div>
    <div class="ratio-chip" onclick="setRatio(1.414,1)"><div class="r">√2:1</div><div class="n">A4 Paper</div></div>
  </div>
</div>
<script>
  function gcd(a,b){return b?gcd(b,a%b):a;}
  function update(){
    const w=+document.getElementById('w').value||0;
    const h=+document.getElementById('h').value||0;
    if(!w||!h)return;
    const g=gcd(w,h);
    const rw=w/g, rh=h/g;
    const dec=(w/h).toFixed(4);
    document.getElementById('ratio-out').textContent=`Ratio: ${rw}:${rh}  |  Decimal: ${dec}  |  ${w}×${h}`;
    const maxW=320, maxH=200;
    let dw=maxW, dh=maxW*(h/w);
    if(dh>maxH){dh=maxH;dw=maxH*(w/h);}
    document.getElementById('rect').style.width=Math.round(dw)+'px';
    document.getElementById('rect').style.height=Math.round(dh)+'px';
  }
  function fromW(){const w=+document.getElementById('w').value;const ratio=w/1920;document.getElementById('h').value=Math.round(1080*ratio);update();}
  function fromH(){const h=+document.getElementById('h').value;const ratio=h/1080;document.getElementById('w').value=Math.round(1920*ratio);update();}
  function setRatio(rw,rh){document.getElementById('w').value=Math.round(rw*100);document.getElementById('h').value=Math.round(rh*100);update();}
  update();
</script>
</body></html>
