
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Meta Tags | Developer OS</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../style.css">
  <style>
    .preview-cards { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:16px; margin-top:20px; }
    .og-card { border-radius:10px; overflow:hidden; border:1px solid var(--border); background:var(--surface); }
    .og-img { height:140px; background:linear-gradient(135deg,var(--accent),var(--accent2)); display:flex; align-items:center; justify-content:center; color:#fff; font-size:2rem; }
    .og-body { padding:12px; }
    .og-domain { font-size:0.7rem; color:var(--muted); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:4px; }
    .og-title { font-size:0.88rem; font-weight:600; margin-bottom:4px; line-height:1.3; }
    .og-desc { font-size:0.75rem; color:var(--muted); line-height:1.4; }
    .tw-card { border-radius:14px; overflow:hidden; border:1px solid #2f3336; background:#000; }
    .tw-img { height:150px; background:linear-gradient(135deg,var(--accent),var(--accent2)); display:flex; align-items:center; justify-content:center; color:#fff; font-size:2rem; }
    .tw-body { padding:12px; }
    .tw-title { font-size:0.88rem; font-weight:700; color:#e7e9ea; margin-bottom:3px; }
    .tw-desc { font-size:0.75rem; color:#71767b; }
    .tw-domain { font-size:0.72rem; color:#71767b; margin-top:6px; }
    .code-out { font-family:'JetBrains Mono',monospace; font-size:0.75rem; background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:14px; margin-top:16px; white-space:pre; overflow-x:auto; }
  </style>
</head>
<body>
<div class="page-header">
  <a href="../index.html" class="back-btn">← Back</a>
  <span class="page-title">🏷️ Meta Tags Generator</span>
</div>
<div class="container">
  <div class="row mb">
    <div class="col"><label>Title</label><input type="text" id="title" value="My Awesome App" oninput="update()"></div>
    <div class="col"><label>URL / Domain</label><input type="text" id="url" value="https://myapp.com" oninput="update()"></div>
  </div>
  <div class="mb">
    <label>Description</label>
    <textarea id="desc" rows="2" oninput="update()">The best app for developers. Fast, reliable, and open source.</textarea>
  </div>
  <div class="row mb">
    <div class="col"><label>Image URL (optional)</label><input type="text" id="img" placeholder="https://…/og-image.png" oninput="update()"></div>
    <div class="col"><label>Author / Site Name</label><input type="text" id="author" value="Developer OS" oninput="update()"></div>
  </div>
  <div class="flex">
    <button class="btn btn-secondary" onclick="copyCode()">📋 Copy HTML</button>
  </div>
  <div class="preview-cards" id="previews"></div>
  <div class="code-out" id="code-out"></div>
</div>
<div class="toast" id="toast">Copied!</div>
<script>
  function domain(url){try{return new URL(url).hostname;}catch{return url;}}
  function update(){
    const title=document.getElementById('title').value||'Title';
    const desc=document.getElementById('desc').value||'';
    const url=document.getElementById('url').value||'https://example.com';
    const img=document.getElementById('img').value;
    const author=document.getElementById('author').value||'';
    const dom=domain(url);
    const imgEl=img?`<img src="${img}" style="width:100%;height:100%;object-fit:cover" onerror="this.style.display='none'">`:'🖼️';
    document.getElementById('previews').innerHTML=`
      <div>
        <div style="font-size:0.72rem;color:var(--muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:.06em">Open Graph (Facebook/LinkedIn)</div>
        <div class="og-card">
          <div class="og-img">${imgEl}</div>
          <div class="og-body">
            <div class="og-domain">${dom}</div>
            <div class="og-title">${esc(title)}</div>
            <div class="og-desc">${esc(desc)}</div>
          </div>
        </div>
      </div>
      <div>
        <div style="font-size:0.72rem;color:var(--muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:.06em">Twitter Card</div>
        <div class="tw-card">
          <div class="tw-img">${imgEl}</div>
          <div class="tw-body">
            <div class="tw-title">${esc(title)}</div>
            <div class="tw-desc">${esc(desc)}</div>
            <div class="tw-domain">🔗 ${dom}</div>
          </div>
        </div>
      </div>`;
    const code=`<!-- Primary Meta Tags -->
<title>${title}</title>
<meta name="title" content="${title}">
<meta name="description" content="${desc}">
<meta name="author" content="${author}">

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:url" content="${url}">
<meta property="og:title" content="${title}">
<meta property="og:description" content="${desc}">${img?`\n<meta property="og:image" content="${img}">`:''} 

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image">
<meta property="twitter:url" content="${url}">
<meta property="twitter:title" content="${title}">
<meta property="twitter:description" content="${desc}">${img?`\n<meta property="twitter:image" content="${img}">`:''} `;
    document.getElementById('code-out').textContent=code;
  }
  function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
  function copyCode(){navigator.clipboard.writeText(document.getElementById('code-out').textContent).then(()=>{const t=document.getElementById('toast');t.classList.add('show');setTimeout(()=>t.classList.remove('show'),1800);});}
  update();
</script>
</body></html>
