<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Number Base Converter – Developer OS</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  body{font-family:'Poppins',sans-serif;background:#0d0d1a;color:#e2e8f0;min-height:100vh}
  a.back{display:inline-flex;align-items:center;gap:8px;color:#a5b4fc;text-decoration:none;font-size:.85rem;font-weight:500;margin-bottom:28px}
  a.back:hover{color:#fff}
  header{background:linear-gradient(160deg,#111128 0%,#1a1a3e 100%);text-align:center;padding:40px 20px 32px;border-bottom:1px solid rgba(99,102,241,.25)}
  header h1{font-size:2rem;font-weight:700;color:#fff}header p{font-size:.95rem;color:#94a3b8;margin-top:6px}
  .container{max-width:700px;margin:0 auto;padding:36px 24px}
  label{display:block;font-size:.82rem;font-weight:600;color:#94a3b8;margin-bottom:8px;text-transform:uppercase;letter-spacing:1px}
  input[type=text],select{width:100%;background:#111128;border:1px solid rgba(99,102,241,.3);color:#e2e8f0;font-family:'Courier New',monospace;font-size:1rem;border-radius:10px;padding:12px 16px;outline:none;transition:border-color .2s}
  input:focus{border-color:#6366f1}
  .row{display:grid;grid-template-columns:1fr 160px;gap:12px;margin-bottom:16px}
  .results{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:8px}
  .res-card{background:#111128;border:1px solid rgba(99,102,241,.2);border-radius:12px;padding:16px;cursor:pointer;transition:border-color .2s}
  .res-card:hover{border-color:#6366f1}
  .res-label{font-size:.72rem;color:#64748b;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px}
  .res-val{font-family:'Courier New',monospace;font-size:.95rem;color:#a5b4fc;word-break:break-all;line-height:1.5}
  .error{color:#f87171;font-size:.85rem;margin-top:8px}
  .toast{position:fixed;bottom:24px;right:24px;background:#6366f1;color:#fff;padding:12px 20px;border-radius:10px;font-size:.85rem;font-weight:600;opacity:0;pointer-events:none;transition:opacity .3s;z-index:999}
  .toast.show{opacity:1}
  @media(max-width:500px){.results{grid-template-columns:1fr}.row{grid-template-columns:1fr}}
</style>
</head>
<body>
<header><h1>🔢 Number Base Converter</h1><p>Convert between Binary, Octal, Decimal, and Hex</p></header>
<div class="container">
  <a class="back" href="../index.html">← Back to Developer OS</a>
  <div class="row">
    <div><label>Input Number</label><input type="text" id="input" placeholder="Enter a number..." oninput="convert()"></div>
    <div><label>From Base</label>
      <select id="fromBase" onchange="convert()" style="font-family:'Poppins',sans-serif">
        <option value="10">Decimal (10)</option>
        <option value="2">Binary (2)</option>
        <option value="8">Octal (8)</option>
        <option value="16">Hex (16)</option>
      </select>
    </div>
  </div>
  <div class="error" id="error"></div>
  <p style="font-size:.8rem;color:#64748b;margin-bottom:12px">Click any result to copy it</p>
  <div class="results">
    <div class="res-card" onclick="copyVal('dec')"><div class="res-label">Decimal (Base 10)</div><div class="res-val" id="dec">—</div></div>
    <div class="res-card" onclick="copyVal('bin')"><div class="res-label">Binary (Base 2)</div><div class="res-val" id="bin">—</div></div>
    <div class="res-card" onclick="copyVal('oct')"><div class="res-label">Octal (Base 8)</div><div class="res-val" id="oct">—</div></div>
    <div class="res-card" onclick="copyVal('hex')"><div class="res-label">Hexadecimal (Base 16)</div><div class="res-val" id="hex">—</div></div>
  </div>
</div>
<div class="toast" id="toast">Copied!</div>
<script>
  function convert(){
    const v=document.getElementById('input').value.trim().toUpperCase();
    const base=parseInt(document.getElementById('fromBase').value);
    document.getElementById('error').textContent='';
    if(!v){['dec','bin','oct','hex'].forEach(id=>document.getElementById(id).textContent='—');return;}
    try{
      const decimal=parseInt(v,base);
      if(isNaN(decimal)) throw new Error('Invalid number for base '+base);
      document.getElementById('dec').textContent=decimal.toString(10);
      document.getElementById('bin').textContent=decimal.toString(2);
      document.getElementById('oct').textContent=decimal.toString(8);
      document.getElementById('hex').textContent=decimal.toString(16).toUpperCase();
    }catch(e){document.getElementById('error').textContent='❌ '+e.message;}
  }
  function copyVal(id){
    const val=document.getElementById(id).textContent;
    if(val==='—') return;
    navigator.clipboard.writeText(val);
    const t=document.getElementById('toast');t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000);
  }
</script>
</body></html>
