<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Password Strength – Developer OS</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  body{font-family:'Poppins',sans-serif;background:#0d0d1a;color:#e2e8f0;min-height:100vh}
  a.back{display:inline-flex;align-items:center;gap:8px;color:#a5b4fc;text-decoration:none;font-size:.85rem;font-weight:500;margin-bottom:28px}
  a.back:hover{color:#fff}
  header{background:linear-gradient(160deg,#111128 0%,#1a1a3e 100%);text-align:center;padding:40px 20px 32px;border-bottom:1px solid rgba(99,102,241,.25)}
  header h1{font-size:2rem;font-weight:700;color:#fff}header p{font-size:.95rem;color:#94a3b8;margin-top:6px}
  .container{max-width:600px;margin:0 auto;padding:36px 24px}
  label{display:block;font-size:.82rem;font-weight:600;color:#94a3b8;margin-bottom:8px;text-transform:uppercase;letter-spacing:1px}
  .input-wrap{position:relative}
  input[type=text],input[type=password]{width:100%;background:#111128;border:1px solid rgba(99,102,241,.3);color:#e2e8f0;font-family:'Poppins',sans-serif;font-size:1rem;border-radius:10px;padding:14px 48px 14px 16px;outline:none;transition:border-color .2s}
  input:focus{border-color:#6366f1}
  .toggle{position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;color:#64748b;cursor:pointer;font-size:1rem}
  .meter{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin:16px 0 8px}
  .meter-seg{height:6px;border-radius:99px;background:#1e1e2e;transition:background .3s}
  .strength-label{font-size:.9rem;font-weight:600;margin-bottom:20px}
  .checks{display:flex;flex-direction:column;gap:10px;background:#111128;border:1px solid rgba(99,102,241,.15);border-radius:12px;padding:18px}
  .check{display:flex;align-items:center;gap:10px;font-size:.88rem;color:#64748b;transition:color .2s}
  .check.pass{color:#34d399}
  .check-icon{font-size:.9rem;width:18px;text-align:center}
  .score-ring{text-align:center;margin:20px 0}
  .score-ring strong{font-size:2.5rem;font-weight:700}
  .score-ring span{display:block;font-size:.8rem;color:#64748b}
</style>
</head>
<body>
<header><h1>💪 Password Strength</h1><p>Check how secure your password is</p></header>
<div class="container">
  <a class="back" href="../index.html">← Back to Developer OS</a>
  <div style="margin-bottom:20px">
    <label>Enter Password</label>
    <div class="input-wrap">
      <input type="password" id="pwd" placeholder="Type your password..." oninput="checkStrength()">
      <button class="toggle" onclick="toggleVis()" id="toggleBtn">👁</button>
    </div>
  </div>
  <div class="meter" id="meter">
    <div class="meter-seg" id="s1"></div><div class="meter-seg" id="s2"></div>
    <div class="meter-seg" id="s3"></div><div class="meter-seg" id="s4"></div><div class="meter-seg" id="s5"></div>
  </div>
  <div class="strength-label" id="strengthLabel" style="color:#64748b">Enter a password to check</div>
  <div class="checks">
    <div class="check" id="c-len"><span class="check-icon">○</span> At least 8 characters</div>
    <div class="check" id="c-upper"><span class="check-icon">○</span> Contains uppercase letter (A-Z)</div>
    <div class="check" id="c-lower"><span class="check-icon">○</span> Contains lowercase letter (a-z)</div>
    <div class="check" id="c-num"><span class="check-icon">○</span> Contains a number (0-9)</div>
    <div class="check" id="c-sym"><span class="check-icon">○</span> Contains a symbol (!@#$...)</div>
    <div class="check" id="c-long"><span class="check-icon">○</span> 12+ characters (strong recommendation)</div>
  </div>
</div>
<script>
  const levels=[{label:'Very Weak',color:'#ef4444'},{label:'Weak',color:'#f97316'},{label:'Fair',color:'#eab308'},{label:'Strong',color:'#22c55e'},{label:'Very Strong',color:'#6366f1'}];
  function toggleVis(){const i=document.getElementById('pwd');i.type=i.type==='password'?'text':'password';}
  function checkStrength(){
    const p=document.getElementById('pwd').value;
    const checks={len:p.length>=8,upper:/[A-Z]/.test(p),lower:/[a-z]/.test(p),num:/[0-9]/.test(p),sym:/[^A-Za-z0-9]/.test(p),long:p.length>=12};
    Object.keys(checks).forEach(k=>{
      const el=document.getElementById('c-'+k);
      el.classList.toggle('pass',checks[k]);
      el.querySelector('.check-icon').textContent=checks[k]?'✓':'○';
    });
    const score=Object.values(checks).filter(Boolean).length;
    const lvl=Math.max(0,Math.min(4,score-1));
    for(let i=1;i<=5;i++){
      const seg=document.getElementById('s'+i);
      seg.style.background=i<=score?levels[lvl].color:'#1e1e2e';
    }
    const l=document.getElementById('strengthLabel');
    if(!p){l.textContent='Enter a password to check';l.style.color='#64748b';}
    else{l.textContent=levels[lvl].label;l.style.color=levels[lvl].color;}
  }
</script>
</body></html>
