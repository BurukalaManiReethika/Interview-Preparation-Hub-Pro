
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Color Converter | Developer OS</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../style.css">
  <style>
    .preview { width:100%; height:120px; border-radius:12px; border:1px solid var(--border); margin-bottom:24px; transition:background 0.2s; }
    .conv-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:16px; }
    .conv-card { background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:14px; }
    .conv-card label { font-size:0.72rem; color:var(--accent2); font-weight:700; letter-spacing:0.08em; text-transform:uppercase; }
    .conv-card input { background:none; border:none; color:var(--text); font-family:'JetBrains Mono',monospace; font-size:0.95rem; font-weight:600; width:100%; outline:none; margin-top:4px; padding:0; }
    .copy-btn { background:none; border:none; color:var(--muted); cursor:pointer; font-size:0.72rem; margin-top:6px; padding:0; transition:color .15s; }
    .copy-btn:hover { color:var(--text); }
  </style>
</head>
<body>
<div class="page-header">
  <a href="../index.html" class="back-btn">← Back</a>
  <span class="page-title">🖌️ Color Converter</span>
</div>
<div class="container">
  <div style="display:flex;gap:16px;align-items:center;margin-bottom:20px">
    <input type="color" id="picker" value="#6c63ff" oninput="fromPicker()" style="width:60px;height:48px;border-radius:8px;border:1px solid var(--border);background:none;cursor:pointer;padding:2px">
    <div style="flex:1">
      <label>Pick or type any value below</label>
    </div>
  </div>
  <div class="preview" id="preview"></div>
  <div class="conv-grid">
    <div class="conv-card">
      <label>HEX</label>
      <input type="text" id="hex" value="#6c63ff" oninput="fromHex(this.value)">
      <button class="copy-btn" onclick="cp('hex')">📋 Copy</button>
    </div>
    <div class="conv-card">
      <label>RGB</label>
      <input type="text" id="rgb" value="rgb(108, 99, 255)" oninput="fromRgb(this.value)">
      <button class="copy-btn" onclick="cp('rgb')">📋 Copy</button>
    </div>
    <div class="conv-card">
      <label>HSL</label>
      <input type="text" id="hsl" value="hsl(243, 100%, 69%)" oninput="fromHsl(this.value)">
      <button class="copy-btn" onclick="cp('hsl')">📋 Copy</button>
    </div>
  </div>
</div>
<div class="toast" id="toast">Copied!</div>
<script>
  function setAll(r,g,b){
    const hex='#'+[r,g,b].map(v=>v.toString(16).padStart(2,'0')).join('');
    const [h,s,l]=rgbToHsl(r,g,b);
    document.getElementById('hex').value=hex;
    document.getElementById('rgb').value=`rgb(${r}, ${g}, ${b})`;
    document.getElementById('hsl').value=`hsl(${h}, ${s}%, ${l}%)`;
    document.getElementById('preview').style.background=hex;
    document.getElementById('picker').value=hex;
  }
  function fromPicker(){fromHex(document.getElementById('picker').value);}
  function fromHex(v){const m=v.trim().match(/^#?([0-9a-f]{3,6})$/i);if(!m)return;let h=m[1];if(h.length===3)h=h.split('').map(c=>c+c).join('');setAll(parseInt(h.slice(0,2),16),parseInt(h.slice(2,4),16),parseInt(h.slice(4,6),16));}
  function fromRgb(v){const m=v.match(/rgb\(\s*(\d+),\s*(\d+),\s*(\d+)\s*\)/i);if(m)setAll(+m[1],+m[2],+m[3]);}
  function fromHsl(v){const m=v.match(/hsl\(\s*(\d+),\s*(\d+)%,\s*(\d+)%\s*\)/i);if(!m)return;const [r,g,b]=hslToRgb(+m[1],+m[2],+m[3]);setAll(r,g,b);}
  function rgbToHsl(r,g,b){r/=255;g/=255;b/=255;const mx=Math.max(r,g,b),mn=Math.min(r,g,b);let h,s,l=(mx+mn)/2;if(mx===mn){h=s=0;}else{const d=mx-mn;s=l>.5?d/(2-mx-mn):d/(mx+mn);switch(mx){case r:h=(g-b)/d+(g<b?6:0);break;case g:h=(b-r)/d+2;break;default:h=(r-g)/d+4;}h/=6;}return[Math.round(h*360),Math.round(s*100),Math.round(l*100)];}
  function hslToRgb(h,s,l){s/=100;l/=100;const c=(1-Math.abs(2*l-1))*s,x=c*(1-Math.abs((h/60)%2-1)),m=l-c/2;let r=0,g=0,b=0;if(h<60){r=c;g=x;}else if(h<120){r=x;g=c;}else if(h<180){g=c;b=x;}else if(h<240){g=x;b=c;}else if(h<300){r=x;b=c;}else{r=c;b=x;}return[Math.round((r+m)*255),Math.round((g+m)*255),Math.round((b+m)*255)];}
  function cp(id){navigator.clipboard.writeText(document.getElementById(id).value).then(()=>{const t=document.getElementById('toast');t.classList.add('show');setTimeout(()=>t.classList.remove('show'),1800);});}
  fromHex('#6c63ff');
</script>
</body></html>
